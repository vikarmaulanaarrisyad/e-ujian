// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  GURU
  STAFF
}

enum Gender {
  L
  P
}

enum SubjectGroup {
  KELOMPOK_A // Nasional
  KELOMPOK_B // Muatan Lokal
  KELOMPOK_C // Ciri Khas Madrasah
}

enum SemesterType {
  ODD
  EVEN
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SchoolProfile {
  id              String   @id @default(uuid())
  name            String
  npsn            String?  @unique
  address         String   @db.Text
  headmaster      String   @map("headmaster_name")
  headmasterNip   String?  @map("headmaster_nip")
  city            String?  // Nama Daerah / Kabupaten
  logoUrl         String?  @map("logo_url")
  sklNumberFormat String?  @map("skl_number_format") // Format nomor SKL, e.g. "B.{seq}/MI.BH/{year}"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("school_profiles")
}

model AcademicYear {
  id          String       @id @default(uuid())
  year        String       // e.g. "2025/2026"
  semester    SemesterType // ODD or EVEN
  isActive    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  gradeWeights GradeWeight[]
  reportGrades ReportGrade[]
  examGrades   ExamGrade[]

  @@unique([year, semester])
  @@map("academic_years")
}

model Student {
  id                String    @id @default(uuid())
  nis               String    @unique
  nisn              String    @unique
  name              String
  gender            Gender
  class             String    @default("6")
  placeOfBirth      String?   @map("place_of_birth")
  dateOfBirth       DateTime? @map("date_of_birth")
  parentName        String?   @map("parent_name")
  // Graduation fields
  isGraduated       Boolean   @default(false) @map("is_graduated")
  graduationDate    DateTime? @map("graduation_date")
  certificateNumber String?   @unique @map("certificate_number")
  sklNumber         String?   @map("skl_number") // Nomor SKL yang ditetapkan
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  reportGrades ReportGrade[]
  examGrades   ExamGrade[]

  @@map("students")
}

model Subject {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique
  group     SubjectGroup
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  reportGrades ReportGrade[]
  examGrades   ExamGrade[]

  @@map("subjects")
}

model GradeWeight {
  id               String   @id @default(uuid())
  reportPercentage Float    @default(60.0) // Bobot Nilai Rapor (e.g. 60.0)
  examPercentage   Float    @default(40.0) // Bobot Nilai Ujian (e.g. 40.0)
  academicYearId   String   @map("academic_year_id")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@map("grade_weights")
}

model ReportGrade {
  id             String   @id @default(uuid())
  studentId      String   @map("student_id")
  subjectId      String   @map("subject_id")
  academicYearId String   @map("academic_year_id")
  semester       Int      // 7, 8, 9, 10, 11 (Kelas 4 Ganjil to Kelas 6 Ganjil)
  score          Float    @db.Double // Nilai (e.g. 0.0 - 100.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, academicYearId, semester])
  @@map("report_grades")
}

model ExamGrade {
  id             String   @id @default(uuid())
  studentId      String   @map("student_id")
  subjectId      String   @map("subject_id")
  academicYearId String   @map("academic_year_id")
  score          Float    @db.Double // Nilai Ujian (e.g. 0.0 - 100.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, academicYearId])
  @@map("exam_grades")
}
