{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for Sistem Pengolahan Nilai Ujian Madrasah (MI) Kelas 6",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "prisma:generate": "prisma generate && prisma generate --schema=prisma/schema.mysql.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:mysql": "prisma migrate dev --schema=prisma/schema.mysql.prisma",
    "prisma:seed": "ts-node scripts/seed.ts"
  },
  "prisma": {
    "seed": "ts-node scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
